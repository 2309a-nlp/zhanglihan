# ==========================================
# Expert RAG System - 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ==========================================

# --- LLM 后端 ---
# 可选: deepseek_api | ollama | vllm | sglang
LLM_BACKEND=deepseek_api

# DeepSeek API Key（官网 https://platform.deepseek.com/ 获取）
DEEPSEEK_API_KEY=sk-your-key-here

# vLLM 配置（仅 LLM_BACKEND=vllm 时有效）
VLLM_BASE_URL=http://172.30.214.232:8001
VLLM_MODEL_NAME=deepseek-chat

# SGLang 配置（仅 LLM_BACKEND=sglang 时有效）
SGLANG_BASE_URL=http://localhost:30000
SGLANG_MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct

# Ollama 配置（仅 LLM_BACKEND=ollama 时有效）
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL_NAME=qwen2.5:1.5b

# --- 服务端口 ---
HOST=127.0.0.1
PORT=8001

# --- RAG 检索 ---
RAG_RETRIEVAL_K=5
RAG_SIMILARITY_THRESHOLD=0.65
USE_RERANKER=true
RERANK_TOP_K=3

# --- Milvus（可选，用于存储对话历史）---
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=root:Milvus

# --- MySQL（长期记忆）---
# 如需修改连接参数，请编辑 backend/services/long_term_memory.py 中的 DB_CONFIG
